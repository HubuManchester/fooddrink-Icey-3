<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="FoodieTracker.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:FoodieTracker.Views">
    <TabBar>
        <ShellContent Title="Foods" Icon="food.png" ContentTemplate="{DataTemplate views:MainPage}"/>
        <ShellContent Title="Hardware" Icon="hardware.png" ContentTemplate="{DataTemplate views:HardwareDemoPage}"/>
        <ShellContent Title="Settings" Icon="settings.png" ContentTemplate="{DataTemplate views:SettingsPage}"/>
    </TabBar>
</Shell>