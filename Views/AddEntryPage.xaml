<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodieTracker.Views.AddEntryPage"
             Title="New Entry">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Basic Information" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"/>
            <Entry x:Name="NameEntry" Placeholder="Food/Drink Name *" />
            <Picker x:Name="CategoryPicker" Title="Category *">
                <Picker.Items>
                    <x:String>Breakfast</x:String>
                    <x:String>Lunch</x:String>
                    <x:String>Dinner</x:String>
                    <x:String>Snack</x:String>
                    <x:String>Drink</x:String>
                </Picker.Items>
            </Picker>
            <Editor x:Name="DescEditor" Placeholder="Description (ingredients, flavor, etc.)" AutoSize="TextChanges" HeightRequest="80"/>

            <Label Text="Nutrition (per serving)" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" Margin="0,8,0,0"/>

            <!-- 第一行：热量和蛋白质 -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Entry x:Name="CalEntry" Placeholder="Calories *" Keyboard="Numeric" />
                <Entry x:Name="ProteinEntry" Grid.Column="1" Placeholder="Protein (g)" Keyboard="Numeric" />
            </Grid>

            <!-- 第二行：碳水和脂肪 -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Entry x:Name="CarbsEntry" Placeholder="Carbs (g)" Keyboard="Numeric" />
                <Entry x:Name="FatEntry" Grid.Column="1" Placeholder="Fat (g)" Keyboard="Numeric" />
            </Grid>

            <Label Text="Dietary Information" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#F29B38, Dark=#FFD18E}" Margin="0,8,0,0"/>
            <Entry x:Name="AllergyEntry" Placeholder="Allergy info (e.g., contains nuts, dairy-free)" />

            <Label x:Name="ErrorLabel" IsVisible="False" TextColor="Red" FontAttributes="Bold" />
            <Button Text="Save Entry" Clicked="OnSaveClicked" BackgroundColor="#2F7A4F" TextColor="White" FontAttributes="Bold" HeightRequest="50"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>