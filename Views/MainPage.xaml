<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodieTracker.Models"
             x:Class="FoodieTracker.Views.MainPage"
             Title="FoodieTracker">
    <Grid RowDefinitions="Auto,*">
        <Grid Padding="16" RowDefinitions="Auto,Auto" RowSpacing="12">
            <SearchBar x:Name="SearchBar" Placeholder="Search food or drink..." TextChanged="OnSearchTextChanged"/>
            <Button Grid.Row="1" Text="➕ Add New" Clicked="OnAddClicked" HorizontalOptions="End" BackgroundColor="#2F7A4F" TextColor="White"/>
        </Grid>
        <RefreshView Grid.Row="1" x:Name="RefreshView" Refreshing="OnRefreshViewRefreshing">
            <CollectionView x:Name="FoodList" ItemsSource="{Binding}" SelectionMode="None" Margin="12">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodEntry">
                        <Border StrokeThickness="1" Padding="12" Margin="0,6">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"/>
                                    <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" MaxLines="2"/>
                                    <Label Text="{Binding CaloriesLabel}" FontSize="14" FontAttributes="Bold" TextColor="Green"/>
                                </VerticalStackLayout>
                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <Button Text="Details" Clicked="OnDetailsClicked" CommandParameter="{Binding Id}" BackgroundColor="#D9472B" TextColor="White"/>
                                    <Button Grid.Row="1" Text="✏️ Edit" Clicked="OnEditClicked" CommandParameter="{Binding Id}" BackgroundColor="#2F7A4F" TextColor="White"/>
                                    <Button Grid.Row="2" Text="🗑️ Delete" Clicked="OnDeleteClicked" CommandParameter="{Binding Id}" BackgroundColor="#D9472B" TextColor="White"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>