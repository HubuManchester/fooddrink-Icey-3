<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodieTracker.Views.DetailPage"
             Title="Details">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label x:Name="NameLabel" FontSize="28" FontAttributes="Bold" />
            <Label x:Name="CatLabel" TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
            <Label x:Name="CalLabel" FontSize="24" FontAttributes="Bold" TextColor="Green" />
            <Label x:Name="MacroLabel" FontSize="16" />
            <Label x:Name="DescLabel" FontSize="15" />
            <Label x:Name="AllergyLabel" FontSize="14" FontAttributes="Italic" TextColor="{AppThemeBinding Light=DarkRed, Dark=LightCoral}" />

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,10">
                <Button Text="🔊 Read"
                        BackgroundColor="{AppThemeBinding Light=#D9472B, Dark=#FF7D55}"
                        TextColor="White"
                        Clicked="OnSpeakClicked" />
                <Button Grid.Column="1"
                        Text="🔇 Stop"
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"
                        TextColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
                        Clicked="OnStopClicked" />
                <Button Grid.Column="2"
                        Text="✏️ Edit"
                        BackgroundColor="#2F7A4F"
                        TextColor="White"
                        Clicked="OnEditClicked" />
            </Grid>

            <Button Text="🗑️ Delete Item"
                    BackgroundColor="#D9472B"
                    TextColor="White"
                    Clicked="OnDeleteClicked" />

            <Button Text="📳 Vibrate Reminder"
                    BackgroundColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}"
                    TextColor="White"
                    Clicked="OnVibrateClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>